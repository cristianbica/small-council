{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "docker", "run",
        "-i", "--rm", "--init",
        "--ipc=host",
        "-v", "/root/p/small-council/tmp/playwright:/tmp",
        "mcr.microsoft.com/playwright/mcp"
      ],
      "enabled": true
    }
  }
}
