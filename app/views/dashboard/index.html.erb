<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">Dashboard</h1>
      <p class="text-base-content/70 mt-1">Overview of your councils and conversations</p>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="stat bg-base-100 shadow rounded-lg">
      <div class="stat-title">Councils</div>
      <div class="stat-value"><%= @councils.count %></div>
      <div class="stat-desc">Active councils</div>
    </div>
    <div class="stat bg-base-100 shadow rounded-lg">
      <div class="stat-title">Conversations</div>
      <div class="stat-value"><%= @conversations.count %></div>
      <div class="stat-desc">Total conversations</div>
    </div>
    <div class="stat bg-base-100 shadow rounded-lg">
      <div class="stat-title">Space</div>
      <div class="stat-value text-lg"><%= Current.space.name %></div>
      <div class="stat-desc"><%= link_to "Switch", spaces_path, class: "link link-primary" %></div>
    </div>
  </div>

  <!-- Councils Section -->
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <h2 class="card-title">Your Councils</h2>
        <span class="badge badge-primary badge-sm"><%= @councils.count %></span>
      </div>

      <% if @councils.any? %>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <% @councils.each do |council| %>
            <div class="card bg-base-200">
              <div class="card-body p-4">
                <h3 class="font-semibold"><%= council.name %></h3>
                <p class="text-sm text-base-content/60"><%= council.description || "No description" %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            title: "No councils yet",
            description: "Create your first council to start collaborating with AI advisors.",
            action_path: new_council_path,
            action_text: "Create Council" %>
      <% end %>
    </div>
  </section>

  <!-- Recent Conversations Section -->
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <h2 class="card-title">Recent Conversations</h2>
        <span class="badge badge-primary badge-sm"><%= @conversations.count %></span>
      </div>

      <% if @conversations.any? %>
        <div class="space-y-3">
          <% @conversations.each do |conversation| %>
            <div class="flex items-center justify-between p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors">
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold truncate"><%= link_to conversation.title || "Untitled conversation", conversation, class: "hover:underline" %></h3>
                <p class="text-sm text-base-content/60">
                  <%= conversation.messages.count %> messages · <%= time_ago_in_words(conversation.created_at) %> ago
                </p>
              </div>
              <div class="flex items-center gap-2 ml-4">
                <span class="badge <%= conversation.active? ? 'badge-success' : 'badge-ghost' %> badge-sm">
                  <%= conversation.status %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            title: "No conversations yet",
            description: "Start a conversation in one of your councils.",
            action_path: councils_path,
            action_text: "View Councils" %>
      <% end %>
    </div>
  </section>
</div>
