<div data-controller="content-generator"
     data-content-generator-profile-value="council"
     data-content-generator-url-value="<%= council.persisted? ? generate_description_council_path(council) : generate_description_councils_path %>">

  <%= form_with model: council, class: "space-y-4" do |f| %>
    <% if council.errors.any? %>
      <div class="alert alert-error">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <h3 class="font-bold"><%= pluralize(council.errors.count, "error") %> prohibited this council from being saved:</h3>
          <ul class="mt-1 list-disc list-inside text-sm">
            <% council.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="form-control">
      <div class="flex items-center justify-between">
        <label class="label">
          <span class="label-text">
            Name
            <span class="text-error" aria-label="required">*</span>
          </span>
        </label>
        <button type="button"
                class="btn btn-sm btn-secondary"
                data-action="click->content-generator#openModal">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Generate with AI
        </button>
      </div>
      <%= f.text_field :name,
          class: "input input-bordered w-full #{'input-error' if council.errors[:name].any?}",
          placeholder: "e.g., Engineering Leadership Council",
          required: true,
          data: { "content-generator-target": "nameField" } %>
      <% if council.errors[:name].any? %>
        <label class="label">
          <span class="label-text-alt text-error flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= council.errors[:name].first %>
          </span>
        </label>
      <% end %>
    </div>

    <div class="form-control">
      <label class="label">
        <span class="label-text">Description</span>
      </label>
      <%= f.text_area :description,
          class: "textarea textarea-bordered w-full #{'textarea-error' if council.errors[:description].any?}",
          rows: 3,
          placeholder: "What is this council for?",
          data: { "content-generator-target": "descriptionField" } %>
      <% if council.errors[:description].any? %>
        <label class="label">
          <span class="label-text-alt text-error flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= council.errors[:description].first %>
          </span>
        </label>
      <% end %>
    </div>

    <div class="card-actions justify-end mt-6">
      <%= link_to "Cancel", councils_path, class: "btn btn-ghost" %>
      <%= f.submit class: "btn btn-primary" %>
    </div>
  <% end %>

  <%# Modal for AI Council Generation %>
  <dialog data-content-generator-target="modal" 
          class="modal"
          data-action="click->content-generator#clickOutside">
    <div class="modal-box">
      <h3 class="font-bold text-lg mb-4">Generate Council with AI</h3>
      
      <p class="text-sm text-base-content/70 mb-4">
        Describe the council's purpose or focus area. The AI will suggest a name and description.
      </p>

      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text">Concept / Purpose</span>
        </label>
        <textarea data-content-generator-target="conceptInput" 
                  class="textarea textarea-bordered w-full"
                  rows="3"
                  placeholder="e.g., A council of senior engineers to discuss architecture decisions and technical strategy"></textarea>
      </div>

      <div data-content-generator-target="errorMessage" 
           class="alert alert-error hidden mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span></span>
      </div>

      <div class="modal-action">
        <button type="button" 
                class="btn btn-ghost"
                data-action="click->content-generator#closeModal">
          Cancel
        </button>
        <button type="button" 
                data-content-generator-target="generateButton"
                data-action="click->content-generator#generate"
                class="btn btn-primary">
          <span data-content-generator-target="loadingIndicator" class="hidden loading loading-spinner loading-xs mr-2"></span>
          Generate Council
        </button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

</div>
