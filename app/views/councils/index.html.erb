<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">Councils</h1>
      <p class="text-base-content/70 mt-1">
        in <%= Current.space.name %>
        <%= link_to "(switch)", spaces_path, class: "link link-primary text-xs" %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Memories", space_memories_path(Current.space), class: "btn btn-ghost" %>
      <%= link_to "New Council", new_space_council_path(Current.space), class: "btn btn-primary" %>
    </div>
  </div>

  <% if @councils.any? %>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% @councils.each do |council| %>
        <%= link_to council, class: "card bg-base-100 shadow hover:shadow-lg transition-all hover:-translate-y-0.5" do %>
          <div class="card-body">
            <h2 class="card-title"><%= council.name %></h2>
            <p class="text-sm text-base-content/60 line-clamp-2">
              <%= council.description.presence || "No description" %>
            </p>

            <div class="flex items-center gap-2 mt-4">
              <span class="text-sm text-base-content/60">
                <%= pluralize(council.advisors.count, "advisor") %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
        title: "No councils yet",
        description: "Create your first council to start collaborating with AI advisors.",
        action_path: new_space_council_path(Current.space),
        action_text: "Create Council" %>
  <% end %>
</div>
