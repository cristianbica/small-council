<div class="space-y-6">
  <!-- Breadcrumbs -->
  <div class="breadcrumbs text-sm">
    <ul>
      <li><%= link_to "Councils", councils_path %></li>
      <li><%= @council.name %></li>
    </ul>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold"><%= @council.name %></h1>
      <p class="text-base-content/70 mt-1"><%= @council.description.presence || "No description" %></p>
      <p class="text-sm text-base-content/60 mt-1">
        Created by <%= @council.user.email %> · <%= time_ago_in_words(@council.created_at) %> ago
      </p>
    </div>

    <div class="flex items-center gap-2">
      <% if @council.user_id == Current.user.id %>
        <%= link_to "Edit Council", edit_council_path(@council), class: "btn btn-ghost btn-sm" %>
        <%= button_to "Delete", @council, method: :delete,
            class: "btn btn-error btn-sm",
            data: { turbo_confirm: "Are you sure? This will permanently delete:\n\n• This council\n• All #{@council.advisors.count} advisor(s) in this council\n• All #{@council.conversations.count} meeting(s)\n• All messages within those meetings\n\nThis action cannot be undone." } %>
      <% end %>
    </div>
  </div>

  <!-- Advisors Section -->
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <h2 class="card-title">Advisors</h2>
        <% if @council.user_id == Current.user.id %>
          <%= link_to "Add Advisor", select_council_advisors_path(@council), class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>

      <% if @advisors.any? %>
        <div class="space-y-3">
          <% @advisors.each do |advisor| %>
            <%= link_to edit_council_advisor_path(@council, advisor),
                class: "flex items-center justify-between p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors" do %>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold truncate"><%= advisor.name %></h3>
                <p class="text-sm text-base-content/60 line-clamp-1">
                  <% if advisor.system_prompt.present? %>
                    <%= advisor.system_prompt.length > 100 ? "#{advisor.system_prompt[0...100]}..." : advisor.system_prompt %>
                  <% else %>
                    No prompt set
                  <% end %>
                </p>
              </div>
              <% if @council.user_id == Current.user.id %>
                <div class="flex items-center gap-2 ml-4" onclick="event.preventDefault();">
                  <%= link_to "Edit", edit_council_advisor_path(@council, advisor), class: "btn btn-xs btn-ghost" %>
                  <%= button_to "Remove", council_advisor_path(@council, advisor),
                      method: :delete,
                      class: "btn btn-xs btn-ghost text-error",
                      data: { turbo_confirm: "Remove this advisor?" } %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            title: "No advisors yet",
            description: "Add advisors to this council to start collaborating.",
            action_path: (@council.user_id == Current.user.id) ? select_council_advisors_path(@council) : nil,
            action_text: "Add First Advisor" %>
      <% end %>
    </div>
  </section>

  <!-- Meetings Section -->
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <h2 class="card-title">Meetings</h2>
        <%= link_to "New Meeting", new_council_conversation_path(@council), class: "btn btn-primary btn-sm" %>
      </div>

      <% if @council.conversations.any? %>
        <div class="space-y-3">
          <% @council.conversations.recent.limit(5).each do |conversation| %>
            <div class="flex items-center gap-2 p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors group" id="<%= dom_id(conversation) %>">
              <%= link_to conversation, class: "flex-1 min-w-0" do %>
                <div class="min-w-0 flex-1">
                  <h3 class="font-semibold truncate"><%= conversation.title %></h3>
                  <p class="text-sm text-base-content/60">
                    <%= conversation.messages.count %> messages ·
                    <% if conversation.last_message_at %>
                      Last activity <%= time_ago_in_words(conversation.last_message_at) %> ago
                    <% else %>
                      Created <%= time_ago_in_words(conversation.created_at) %> ago
                    <% end %>
                  </p>
                </div>
              <% end %>
              <div class="flex items-center gap-2 ml-4">
                <span class="badge <%= conversation.active? ? 'badge-success' : 'badge-ghost' %> badge-sm">
                  <%= conversation.status %>
                </span>
                <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                  <% if can_delete_conversation?(conversation) %>
                    <div class="dropdown dropdown-end">
                      <button tabindex="0" class="btn btn-ghost btn-xs btn-circle" title="Conversation actions" aria-label="Conversation actions">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6h.01M12 12h.01M12 18h.01" />
                        </svg>
                      </button>
                      <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-36 z-20">
                        <% if conversation.active? && can_delete_conversation?(conversation) %>
                          <li>
                            <%= button_to archive_conversation_path(conversation), method: :post, class: "w-full text-left" do %>
                              Archive
                            <% end %>
                          </li>
                        <% end %>
                        <li>
                          <%= button_to conversation_path(conversation),
                              method: :delete,
                              class: "w-full text-left text-error",
                              data: { turbo_confirm: "Delete this meeting?" } do %>
                            Delete
                          <% end %>
                        </li>
                      </ul>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
          <% if @council.conversations.count > 5 %>
            <div class="text-center mt-4">
              <%= link_to "View all #{@council.conversations.count} meetings →", council_conversations_path(@council), class: "link link-primary" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            title: "No meetings yet",
            description: "Start a meeting to collaborate with your advisors.",
            action_path: new_council_conversation_path(@council),
            action_text: "Start First Meeting" %>
      <% end %>
    </div>
  </section>

  <!-- Back link -->
  <%= link_to "← Back to Councils", councils_path, class: "btn btn-ghost" %>
</div>
