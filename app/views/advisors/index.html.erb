<div class="max-w-4xl mx-auto">
  <!-- Breadcrumbs -->
  <div class="breadcrumbs text-sm mb-4">
    <ul>
      <li><%= link_to "Spaces", spaces_path %></li>
      <li><%= link_to @space.name, @space %></li>
      <li>Advisors</li>
    </ul>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">Advisors in <%= @space.name %></h1>
      <p class="text-base-content/60 mt-1">
        Manage AI advisors for this space. These advisors can be added to any council within the space.
      </p>
    </div>
    <%= link_to new_space_advisor_path(@space), class: "btn btn-primary" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Advisor
    <% end %>
  </div>

  <!-- Scribe Section -->
  <% if @scribe.present? %>
    <section class="card bg-primary/5 border border-primary/20 mb-6">
      <div class="card-body">
        <div class="flex items-center gap-3">
          <div class="avatar placeholder">
            <div class="bg-primary text-primary-content rounded-full w-12 h-12">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
          </div>
          <div>
            <h2 class="card-title text-lg"><%= @scribe.name %></h2>
            <p class="text-sm text-base-content/70">
              The Scribe automatically moderates discussions in "Moderated" mode. 
              It is automatically added to every council in this space.
            </p>
          </div>
          <div class="ml-auto badge badge-primary">Auto-created</div>
        </div>
      </div>
    </section>
  <% end %>

  <!-- Advisors List -->
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <% if @advisors.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>Advisor</th>
                <th>Model</th>
                <th>Description</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @advisors.each do |advisor| %>
                <tr>
                  <td>
                    <div class="flex items-center gap-3">
                      <div class="avatar placeholder">
                        <div class="bg-neutral text-neutral-content rounded-full w-10">
                          <span class="text-sm"><%= advisor.name.first.upcase %></span>
                        </div>
                      </div>
                      <div>
                        <div class="font-medium"><%= link_to advisor.name, space_advisor_path(@space, advisor), class: "hover:underline" %></div>
                        <div class="text-sm text-base-content/60">
                          <%= pluralize(advisor.councils.count, "council") %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <% if advisor.llm_model.present? %>
                      <span class="badge badge-ghost text-xs whitespace-nowrap"><%= advisor.llm_model.name %></span>
                    <% else %>
                      <span class="badge badge-ghost text-xs">No model</span>
                    <% end %>
                  </td>
                  <td>
                    <p class="text-sm text-base-content/70 line-clamp-2">
                      <%= advisor.short_description.presence || advisor.system_prompt&.truncate(100) || "No description" %>
                    </p>
                  </td>
                  <td class="text-right">
                    <div class="flex justify-end gap-2">
                      <%= link_to edit_space_advisor_path(@space, advisor), class: "btn btn-ghost btn-sm" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Edit
                      <% end %>
                      <%= button_to space_advisor_path(@space, advisor), 
                          method: :delete,
                          class: "btn btn-ghost btn-sm text-error",
                          data: { turbo_confirm: "Are you sure you want to delete this advisor?" } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Delete
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            title: "No advisors yet",
            description: "Create your first advisor to add to councils in this space." %>
      <% end %>
    </div>
  </section>

  <!-- Info Box -->
  <div class="alert alert-info mt-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div>
      <p class="font-medium">How advisors work</p>
      <p class="text-sm">
        Advisors created here are available for all councils in this space. 
        When creating or editing a council, you'll select which advisors to include. 
        The Scribe is automatically added to every council and handles "Moderated" discussions.
      </p>
    </div>
  </div>
</div>
