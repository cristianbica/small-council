<div class="max-w-4xl mx-auto">
  <!-- Breadcrumbs -->
  <div class="breadcrumbs text-sm mb-4">
    <ul>
      <li><%= link_to "Councils", councils_path %></li>
      <li><%= link_to @council.name, @council %></li>
      <li>Add Advisors</li>
    </ul>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">Add Advisors to <%= @council.name %></h1>
      <p class="text-base-content/60 mt-1">
        Select from available advisors in this space to add to the council.
      </p>
    </div>
    <%= link_to "Back to Council", @council, class: "btn btn-ghost" %>
  </div>

  <% if @available_advisors.any? %>
    <%= form_with url: add_existing_council_advisors_path(@council), method: :post, class: "space-y-4" do %>
      <section class="card bg-base-100 shadow">
        <div class="card-body">
          <div class="space-y-3">
            <% @available_advisors.each do |advisor| %>
              <label class="flex items-center gap-4 p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors cursor-pointer">
                <%= check_box_tag "advisor_ids[]", advisor.id, false, class: "checkbox" %>
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <span class="font-semibold"><%= advisor.name %></span>
                    <% if advisor.llm_model.present? %>
                      <span class="badge badge-ghost text-xs whitespace-nowrap"><%= advisor.llm_model.name %></span>
                    <% end %>
                  </div>
                  <p class="text-sm text-base-content/60 mt-1">
                    <%= advisor.short_description.presence || advisor.system_prompt&.truncate(100) || "No description" %>
                  </p>
                </div>
              </label>
            <% end %>
          </div>
        </div>
      </section>

      <div class="card-actions justify-end">
        <%= link_to "Cancel", @council, class: "btn btn-ghost" %>
        <%= submit_tag "Add Selected Advisors", class: "btn btn-primary" %>
      </div>
    <% end %>
  <% else %>
    <section class="card bg-base-100 shadow">
      <div class="card-body text-center py-12">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <h2 class="text-xl font-semibold mb-2">No available advisors</h2>
        <p class="text-base-content/60 mb-4">
          All advisors in this space are already part of this council.
        </p>
        <div class="flex justify-center gap-2">
          <%= link_to "Create New Advisor", new_space_advisor_path(@space), class: "btn btn-primary" %>
          <%= link_to "Back to Council", @council, class: "btn btn-ghost" %>
        </div>
      </div>
    </section>
  <% end %>
</div>
