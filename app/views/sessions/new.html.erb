<div class="flex min-h-[70vh] items-center justify-center">
  <div class="card bg-base-100 shadow-xl w-full max-w-md">
    <div class="card-body">
      <h1 class="card-title text-2xl justify-center mb-6">Sign in</h1>

      <%= form_with(url: sign_in_path, class: "space-y-4") do |form| %>
        <div class="form-control">
          <label class="label">
            <span class="label-text">Email</span>
          </label>
          <%= form.email_field :email, value: params[:email_hint], required: true, autofocus: true, autocomplete: "email", class: "input input-bordered w-full", placeholder: "you@example.com" %>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text">Password</span>
          </label>
          <%= form.password_field :password, required: true, autocomplete: "current-password", class: "input input-bordered w-full", placeholder: "••••••••" %>
          <label class="label">
            <span class="label-text-alt">
              <%= link_to "Forgot your password?", new_identity_password_reset_path, class: "link link-hover" %>
            </span>
          </label>
        </div>

        <div class="form-control mt-6">
          <%= form.submit "Sign in", class: "btn btn-primary" %>
        </div>
      <% end %>

      <div class="divider">OR</div>

      <div class="text-center">
        <span class="text-base-content/60">Don't have an account?</span>
        <%= link_to "Sign up", sign_up_path, class: "link link-primary ml-1" %>
      </div>
    </div>
  </div>
</div>
