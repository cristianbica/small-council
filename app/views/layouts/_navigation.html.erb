<div class="navbar bg-base-200 shadow-sm">
  <div class="navbar-start">
    <%= link_to "Small Council", root_path, class: "btn btn-ghost text-xl" %>
  </div>

  <div class="navbar-center hidden lg:flex">
    <% if authenticated? %>
      <ul class="menu menu-horizontal px-1">
        <% if Current.space.present? %>
          <li>
            <%= link_to conversations_path,
                class: "#{'active' if controller_name == 'conversations'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
              Conversations
            <% end %>
          </li>
          <li>
            <%= link_to space_councils_path(Current.space),
                class: "#{'active' if controller_name == 'councils' && params[:space_id].present?}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Councils
            <% end %>
          </li>
          <li>
            <%= link_to space_advisors_path(Current.space),
                class: "#{'active' if controller_name == 'advisors' && params[:space_id].present?}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              Advisors
            <% end %>
          </li>
          <li>
            <%= link_to space_memories_path(Current.space),
                class: "#{'active' if controller_name == 'memories'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              Memories
            <% end %>
          </li>
        <% else %>
          <li>
            <%= link_to spaces_path, class: "#{'active' if controller_name == 'spaces'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              Spaces
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <div class="navbar-end">
    <%= render "layouts/space_switcher" %>
    <% if authenticated? %>
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar placeholder">
          <div class="bg-neutral text-neutral-content rounded-full w-10">
            <span class="text-xl"><%= Current.user.email.first.upcase %></span>
          </div>
        </div>
        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
          <li class="menu-title">
            <span class="text-xs text-base-content/60">Signed in as</span>
            <span class="text-sm font-normal truncate"><%= Current.user.email %></span>
          </li>
          <li class="menu-title mt-2">
            <span class="text-xs text-base-content/60">Account</span>
          </li>
          <li><%= link_to "AI Providers", providers_path %></li>
          <li><%= link_to "Settings", edit_settings_path %></li>
          <li class="menu-title mt-2">
            <span class="text-xs text-base-content/60">Session</span>
          </li>
          <li><%= link_to "Manage Sessions", sessions_path %></li>
          <li><%= button_to "Sign out", session_path(id: Current.session.id), method: :delete, class: "btn btn-ghost btn-sm justify-start w-full" %></li>
        </ul>
      </div>
    <% else %>
      <%= link_to "Sign in", sign_in_path, class: "btn btn-ghost" %>
      <%= link_to "Create account", sign_up_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<% if authenticated? %>
  <!-- Mobile navigation -->
  <div class="lg:hidden navbar bg-base-200 border-t border-base-300">
    <div class="flex-1 flex justify-center">
      <% if Current.space.present? %>
        <%= link_to conversations_path,
            class: "btn btn-ghost flex-1 rounded-none flex-col gap-1 py-2 #{'btn-active' if controller_name == 'conversations'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <span class="text-xs">Conversations</span>
        <% end %>
        <%= link_to space_councils_path(Current.space),
            class: "btn btn-ghost flex-1 rounded-none flex-col gap-1 py-2 #{'btn-active' if controller_name == 'councils' && params[:space_id].present?}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-xs">Councils</span>
        <% end %>
        <%= link_to space_advisors_path(Current.space),
            class: "btn btn-ghost flex-1 rounded-none flex-col gap-1 py-2 #{'btn-active' if controller_name == 'advisors' && params[:space_id].present?}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <span class="text-xs">Advisors</span>
        <% end %>
        <%= link_to space_memories_path(Current.space),
            class: "btn btn-ghost flex-1 rounded-none flex-col gap-1 py-2 #{'btn-active' if controller_name == 'memories'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span class="text-xs">Memories</span>
        <% end %>
      <% else %>
        <%= link_to spaces_path,
            class: "btn btn-ghost flex-1 rounded-none flex-col gap-1 py-2 #{'btn-active' if controller_name == 'spaces'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span class="text-xs">Spaces</span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
