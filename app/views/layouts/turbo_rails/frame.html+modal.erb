<%= turbo_frame_tag "page-modal" do %>
  <dialog data-page-modal-target="modalDialog"
          data-action="close->page-modal#closeDialog"
          class="modal">
    <div class="modal-box w-11/12 h-11/12"> <%# extra classes are for tailwindcss to see them %>
      <form method="dialog">
        <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
      </form>
      <%= yield %>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
<% end %>
