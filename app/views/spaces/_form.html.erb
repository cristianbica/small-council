<%= form_with model: space, class: "space-y-4" do |f| %>
  <% if space.errors.any? %>
    <div class="alert alert-error">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="font-bold"><%= pluralize(space.errors.count, "error") %> prohibited this space from being saved:</h3>
        <ul class="mt-1 list-disc list-inside text-sm">
          <% space.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="form-control">
    <label class="label">
      <span class="label-text">
        Name
        <span class="text-error" aria-label="required">*</span>
      </span>
    </label>
    <%= f.text_field :name,
        class: "input input-bordered w-full #{'input-error' if space.errors[:name].any?}",
        placeholder: "e.g., Product Team, Personal Projects",
        required: true %>
    <% if space.errors[:name].any? %>
      <label class="label">
        <span class="label-text-alt text-error flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= space.errors[:name].first %>
        </span>
      </label>
    <% end %>
  </div>

  <div class="form-control">
    <label class="label">
      <span class="label-text">Description</span>
    </label>
    <%= f.text_area :description,
        class: "textarea textarea-bordered w-full #{'textarea-error' if space.errors[:description].any?}",
        rows: 3,
        placeholder: "What is this space for?" %>
    <% if space.errors[:description].any? %>
      <label class="label">
        <span class="label-text-alt text-error flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= space.errors[:description].first %>
        </span>
      </label>
    <% end %>
  </div>

  <div class="card-actions justify-end mt-6">
    <%= link_to "Cancel", spaces_path, class: "btn btn-ghost" %>
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
