<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold">Search Memory: <%= @space.name %></h1>
      <p class="text-sm text-base-content/60">
        Search results for "<%= @query %>"
      </p>
    </div>
    <%= link_to "← Back to Memory", memory_space_path(@space), class: "btn btn-ghost btn-sm" %>
  </div>

  <!-- Search Form -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <%= form_with url: search_memory_space_path(@space), method: :get, class: "flex gap-2" do |f| %>
        <div class="form-control flex-1">
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-base-content/50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </span>
            <%= f.text_field :q,
                value: @query,
                placeholder: "Search memory...",
                class: "input input-bordered w-full pl-10" %>
          </div>
        </div>
        <%= f.submit "Search", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <!-- Results -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <% if @query.present? %>
        <% if @results&.any? %>
          <h2 class="card-title mb-4"><%= @results.count %> matches found</h2>
          <div class="space-y-2">
            <% @results.each do |line| %>
              <div class="p-3 bg-base-200 rounded-lg border-l-4 border-primary">
                <%= highlight(line, @query, highlighter: '<mark class="bg-primary/20 text-primary-content font-semibold">\1</mark>') %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-base-content/30 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-base-content/60">No matches found for "<strong><%= @query %></strong>".</p>
            <p class="text-sm text-base-content/50 mt-1">Try a different search term.</p>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-base-content/30 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <p class="text-base-content/60">Enter a search term above to search your space memory.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
