<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold">Memory: <%= @space.name %></h1>
      <p class="text-sm text-base-content/60">
        Cumulative knowledge from all resolved conversations
      </p>
    </div>
    <%= link_to "← Back to Space", space_councils_path(@space), class: "btn btn-ghost btn-sm" %>
  </div>

  <!-- Search -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <%= form_with url: search_memory_space_path(@space), method: :get, class: "flex gap-2" do |f| %>
        <div class="form-control flex-1">
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-base-content/50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </span>
            <%= f.text_field :q,
                value: params[:q],
                placeholder: "Search memory...",
                class: "input input-bordered w-full pl-10" %>
          </div>
        </div>
        <%= f.submit "Search", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Cumulative Space Memory -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title">Cumulative Knowledge</h2>
        <% if @space.memory.present? %>
          <div class="prose max-w-none max-h-[60vh] overflow-y-auto bg-base-200 rounded-lg p-4">
            <%= simple_format(@space.memory) %>
          </div>
        <% else %>
          <div class="bg-base-200 rounded-lg p-8 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-base-content/30 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <p class="text-base-content/60">No memories yet. Finish conversations to build knowledge.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Conversation Summaries -->
    <div class="space-y-4">
      <h2 class="text-xl font-bold">Conversation History</h2>

      <% if @resolved_conversations.any? %>
        <% @resolved_conversations.each do |conv| %>
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-sm"><%= conv.title %></h3>
              <p class="text-xs text-base-content/60"><%= conv.council_name %> · Resolved <%= time_ago_in_words(conv.updated_at) %> ago</p>

              <% memory = conv.context["memory"] %>
              <% memory_data = memory.is_a?(String) ? JSON.parse(memory) : memory %>

              <% if memory_data.present? %>
                <div class="mt-2 space-y-2 text-sm">
                  <% if memory_data["key_decisions"].present? %>
                    <div>
                      <p class="font-semibold text-xs text-base-content/70">Key Decisions:</p>
                      <p class="line-clamp-2"><%= memory_data["key_decisions"] %></p>
                    </div>
                  <% end %>

                  <% if memory_data["action_items"].present? %>
                    <div>
                      <p class="font-semibold text-xs text-base-content/70">Action Items:</p>
                      <p class="line-clamp-2"><%= memory_data["action_items"] %></p>
                    </div>
                  <% end %>
                </div>

                <%= link_to "View Full Summary", conversation_path(conv),
                    class: "btn btn-xs btn-ghost mt-2" %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="bg-base-200 rounded-lg p-8 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-base-content/30 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <p class="text-base-content/60">No resolved conversations yet.</p>
          <p class="text-sm text-base-content/50 mt-1">Finish conversations to see them here.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
