<%= turbo_frame_tag "page-modal" do %>
  <dialog data-page-modal-target="modalDialog"
          data-action="close->page-modal#closeDialog"
          class="modal">
    <div class="modal-box w-11/12 max-w-5xl">
      <form method="dialog">
        <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
      </form>

      <div class="mb-4">
        <div class="flex items-center gap-2 mb-1">
          <span class="badge badge-ghost badge-sm"><%= memory.id %></span>
          <h3 class="font-bold text-lg"><%= memory.title %></h3>
        </div>
      </div>

      <div class="prose max-w-none markdown-body max-h-[60vh] overflow-y-auto">
        <%= markdown_to_html(memory.content) %>
      </div>
    </div>

    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
<% end %>
