<%# app/views/conversations/index.html.erb %>
<%# Shows either council-specific conversations or adhoc conversations %>

<div class="space-y-6">
  <!-- Breadcrumbs -->
  <div class="breadcrumbs text-sm">
    <ul>
      <% if @council %>
        <li><%= link_to "Councils", councils_path %></li>
        <li><%= link_to @council.name, @council %></li>
        <li>Conversations</li>
      <% else %>
        <li>Conversations</li>
      <% end %>
    </ul>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">
        <%= @council ? "#{@council.name} Conversations" : "Conversations" %>
      </h1>
      <p class="text-base-content/70 mt-1">
        <% if @council %>
          <% participant_count = @council.advisors.count %>
          <%= participant_count %> advisor<%= "s" if participant_count != 1 %> in this council
        <% else %>
          Direct conversations with advisors across all spaces
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if @council %>
        <%= link_to "New Meeting", new_council_conversation_path(@council), class: "btn btn-primary" %>
      <% else %>
        <%= link_to "Start Conversation", new_conversation_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <!-- Conversations List -->
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <% if @conversations.any? %>
        <div class="space-y-3" id="conversations_list">
          <% @conversations.each do |conversation| %>
            <div class="flex items-center gap-2 p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors group" id="<%= dom_id(conversation) %>">
              <%= link_to conversation, class: "flex-1 min-w-0" do %>
                <div class="flex items-center gap-2">
                  <div class="avatar placeholder">
                    <div class="bg-neutral text-neutral-content rounded-full w-6 h-6">
                      <span class="text-xs"><%= conversation.user.email.first.upcase %></span>
                    </div>
                  </div>
                  <h3 class="font-semibold truncate"><%= conversation.title %></h3>
                  <span class="badge <%= status_badge_class(conversation) %> badge-sm">
                    <%= conversation.status %>
                  </span>
                  <% if conversation.adhoc? %>
                    <span class="badge badge-secondary badge-sm">Conversation</span>
                  <% end %>
                </div>
                <div class="text-sm text-base-content/60 mt-1 flex items-center gap-2">
                  <span>
                    <% if conversation.council_meeting? %>
                      in <%= conversation.council.name %> ·
                    <% end %>
                    <%= conversation.participant_advisors.count %> participant<%= "s" if conversation.participant_advisors.count != 1 %>
                  </span>
                  <span>·</span>
                  <span>
                    <% if conversation.last_message_at %>
                      Last activity <%= time_ago_in_words(conversation.last_message_at) %> ago
                    <% else %>
                      Created <%= time_ago_in_words(conversation.created_at) %> ago
                    <% end %>
                  </span>
                </div>
              <% end %>
              <div class="ml-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="dropdown dropdown-end">
                  <button tabindex="0" class="btn btn-ghost btn-xs btn-circle" title="Conversation actions" aria-label="Conversation actions">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6h.01M12 12h.01M12 18h.01" />
                    </svg>
                  </button>
                  <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-36 z-20">
                    <% if conversation.active? && can_delete_conversation?(conversation) %>
                      <li>
                        <%= button_to archive_conversation_path(conversation), method: :post, class: "w-full text-left" do %>
                          Archive
                        <% end %>
                      </li>
                    <% end %>
                    <% if can_delete_conversation?(conversation) %>
                      <li>
                        <%= button_to conversation_path(conversation),
                            method: :delete,
                            class: "w-full text-left text-error",
                            data: { turbo_confirm: "Delete this conversation?" } do %>
                          Delete
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            title: "No conversations yet",
            description: @council ? "Start a conversation to collaborate with your council advisors." : "Start a direct conversation with any advisor.",
            action_path: @council ? new_council_conversation_path(@council) : new_conversation_path,
            action_text: @council ? "Start First Conversation" : "Start Conversation" %>
      <% end %>
    </div>
  </section>

  <!-- Back link -->
  <% if @council %>
    <%= link_to "← Back to Council", @council, class: "btn btn-ghost" %>
  <% end %>
</div>
