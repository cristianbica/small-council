<%= turbo_stream_from "conversation_#{conversation.id}" %>

<%
  slash_commands = [
    { name: "advisors", description: "Open advisors list" },
    { name: "invite", description: "Add advisor" },
    { name: "kick", description: "Remove advisor" },
    { name: "memories", description: "List memories" },
    { name: "memory", description: "Open memory by id" },
    { name: "attach", description: "Attach memory by id" }
  ]
%>

<div class="chat-main flex flex-col h-full" data-controller="conversation mentions"
      data-mentions-advisors-value='<%= mentionable_advisors.to_json %>'
      data-mentions-commands-value='<%= slash_commands.to_json %>'>

  <header class="flex-none px-6 py-4 border-b border-base-200 bg-base-100">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3 flex-wrap">
        <div class="flex items-center gap-2">
          <%= render "conversations/title", conversation: conversation %>
        </div>
        <span id="conversation_status" class="badge <%= status_badge_class(conversation) %> badge-sm">
          <%= conversation.status %>
        </span>
        <span class="badge badge-outline badge-sm">
          <%= conversation.roe_type.humanize %>
        </span>
      </div>

      <div class="flex items-center gap-2">
        <% if conversation.active? && available_advisors&.any? %>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-outline btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
              </svg>
              Invite
            </div>
            <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52 z-10">
              <% available_advisors.each do |advisor| %>
                <li>
                  <%= button_to invite_advisor_conversation_path(conversation, advisor_id: advisor.id), method: :post, class: "w-full text-left" do %>
                    <div class="flex items-center gap-2">
                      <div class="avatar placeholder">
                        <div class="bg-neutral text-neutral-content rounded-full w-6 flex items-center justify-center">
                          <span class="text-xs"><%= advisor.name.first.upcase %></span>
                        </div>
                      </div>
                      <span><%= advisor.name %></span>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% if conversation.council_meeting? && conversation.active? && can_delete_conversation?(conversation) %>
          <%= button_to finish_conversation_path(conversation),
              method: :post,
              class: "btn btn-primary btn-sm",
              data: { turbo_confirm: "Finish this meeting and mark it as resolved?" } do %>
            Finish
          <% end %>
        <% end %>
      </div>
    </div>

    <%= render "conversations/participant_badges", conversation: conversation %>

    <% if conversation.resolved? %>
      <div class="alert alert-success mt-3 py-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-sm">Conversation resolved.</span>
      </div>
    <% end %>
  </header>

  <div class="messages-area flex-1 overflow-y-auto py-8 px-6 relative" data-conversation-target="messagesContainer">
    <button data-conversation-target="scrollButton"
            data-action="click->conversation#scrollToBottom"
            class="scroll-to-latest hidden btn btn-circle btn-primary shadow-lg"
            title="Scroll to latest messages">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </button>

    <div id="messages" class="max-w-4xl mx-auto space-y-6">
      <% if messages.any? %>
        <% messages.each do |message| %>
          <%= render "conversations/message", message: message %>
        <% end %>
      <% else %>
        <%= render "shared/empty_state",
            title: "No messages yet",
            description: "Start the conversation by typing your first message below. Use @all to include all participants, or @advisor-name to mention specific advisors." %>
      <% end %>
    </div>
  </div>

  <% if conversation.active? %>
    <%= render "conversations/composer", conversation: conversation, new_message: new_message %>
  <% end %>
</div>
