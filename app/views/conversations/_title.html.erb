<div id="conversation_<%= conversation.id %>_title" class="flex items-center gap-2">
  <% edit_toggle_id = "edit_conversation_title_#{conversation.id}" %>
  <input id="<%= edit_toggle_id %>" type="checkbox" class="peer sr-only" />

  <h1 class="conversation-title-<%= conversation.id %> text-lg font-semibold truncate max-w-[14rem] md:max-w-[22rem] peer-checked:hidden"><%= conversation.title %></h1>

  <label for="<%= edit_toggle_id %>" class="btn btn-ghost btn-sm btn-circle peer-checked:hidden" title="Edit conversation title" aria-label="Edit conversation title">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
    </svg>
  </label>

  <div class="hidden peer-checked:flex items-center gap-2">
    <%= form_with model: conversation,
        url: conversation_path(conversation),
        method: :patch,
        class: "flex items-center gap-2" do |form| %>
      <%= form.text_field :title,
          value: conversation.title,
          class: "input input-bordered input-sm w-56 md:w-72",
          maxlength: 255,
          aria: { label: "Conversation title" } %>
      <%= form.button type: :submit, class: "btn btn-ghost btn-sm" do %>
        Save
      <% end %>
    <% end %>

    <label for="<%= edit_toggle_id %>" class="btn btn-ghost btn-sm">Cancel</label>
  </div>
</div>
