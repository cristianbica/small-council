<%# Conversations show page - Stage 1: Layout Foundation %>
<%# Two-column layout: sidebar (w-80) + chat area %>

<%# Wrapper for full-height chat in application layout context %>
<div class="h-[calc(100vh-5rem)] flex overflow-hidden">
  <% if @sidebar_conversations.present? %>
    <%# Left Sidebar: Conversation List %>
    <aside id="conversation-sidebar" class="w-80 flex-none border-r bg-base-200 overflow-y-auto overflow-x-hidden hidden lg:block" data-controller="conversation-sidebar">
      <div class="p-4 border-b bg-base-100">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-lg">Conversations</h2>
          <%= button_to quick_create_conversations_path,
              method: :post,
              class: "btn btn-primary btn-sm btn-circle",
              title: "New conversation" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          <% end %>
        </div>
        <p class="text-xs text-base-content/60">
          <%= Current.account.conversations.adhoc_conversations.count %> total conversations
        </p>
      </div>

      <ul id="conversation-list" class="w-full space-y-1 p-2">
        <% @sidebar_conversations.each do |conv| %>
          <%= render "conversations/sidebar_conversation_item", conv: conv %>
        <% end %>
      </ul>
    </aside>

    <%# Mobile Toggle Button (visible on small screens) %>
    <div class="lg:hidden fixed top-20 left-4 z-30">
      <label for="conversation-drawer" class="btn btn-ghost btn-sm drawer-button">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>

    <%# Mobile Drawer %>
    <div class="drawer lg:hidden">
      <input id="conversation-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content">
        <%# Main content goes here - rendered below %>
      </div>
      <div class="drawer-side z-40 overflow-x-hidden">
        <label for="conversation-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
        <div class="menu bg-base-200 text-base-content min-h-full w-80 p-4">
          <div class="p-4 border-b bg-base-100 -mx-4 -mt-4 mb-4">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-semibold text-lg">Conversations</h2>
              <%= button_to quick_create_conversations_path,
                  method: :post,
                  class: "btn btn-primary btn-sm btn-circle",
                  title: "New conversation" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
              <% end %>
            </div>
          </div>
          <ul class="w-full space-y-1 overflow-x-hidden p-1">
            <% @sidebar_conversations.each do |conv| %>
              <%= render "conversations/sidebar_conversation_item", conv: conv %>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Main Content: Chat Area %>
  <%
    # Build mentionable list: @all + all participants including scribe
    mentionable_advisors = @conversation.all_participant_advisors.map { |a| { name: a.name } }
    mentionable_advisors.unshift({ name: "all" })
  %>

  <div class="flex-1 flex flex-col min-w-0 h-full">
    <%= render "conversations/chat",
        conversation: @conversation,
        messages: @messages,
        new_message: @new_message,
        available_advisors: @available_advisors,
        mentionable_advisors: mentionable_advisors %>
  </div>
</div>
