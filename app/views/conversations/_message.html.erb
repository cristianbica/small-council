<%= turbo_frame_tag "message_#{message.id}", data: { action: "turbo:frame-load->conversation#messageRendered" } do %>
  <% is_current_user = message.sender_type == "User" %>
  <% is_pending = message.pending? %>
  <% is_responding = message.responding? %>
  <% is_loading = is_pending || is_responding %>
  <% is_error = message.error? %>
  <% is_api_error = is_error && message.content.to_s.match?(/API Error|Empty response from AI/) %>
  <% sender_is_advisor = message.sender.is_a?(Advisor) %>
  <% is_advisor = message.advisor? || sender_is_advisor %>
  <% sender_name = message.sender.respond_to?(:name) ? message.sender.name : message.sender.email %>
  <% alignment = is_current_user ? "chat-end" : "chat-start" %>
  <% bubble_class = is_current_user ? "bg-primary text-primary-content" : "bg-base-200 text-base-content" %>
  <% avatar_class = is_advisor ? "bg-primary text-primary-content" : "bg-neutral text-neutral-content" %>
  <% displayed_content = (sender_is_advisor && is_loading) ? "..." : message.content %>

  <div class="chat <%= alignment %> group" id="message_<%= message.id %>">
    <div class="chat-image avatar">
      <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold <%= avatar_class %>">
        <%= sender_name.first.upcase %>
      </div>
    </div>

    <div class="chat-header">
      <%= sender_name %>
      <time class="text-xs opacity-60 ml-2" title="<%= message.created_at.strftime('%B %d, %Y at %I:%M %p') %>">
        <%= time_ago_in_words(message.created_at) %> ago
      </time>
      <% if is_loading %>
        <span class="loading loading-spinner loading-xs ml-2"></span>
      <% end %>
    </div>

    <div class="chat-bubble <%= bubble_class %> text-sm max-w-[85%] sm:max-w-[75%] whitespace-pre-wrap"><%-
      if is_error -%><div class="flex items-center gap-2 text-error-content"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><%= displayed_content %></div><%-
      elsif sender_is_advisor && displayed_content.present? && displayed_content.length > 500 -%><div data-controller="message-expand" data-message-expand-max-length-value="500"><div data-message-expand-target="content" class="<%= is_loading ? 'animate-pulse' : '' %>"><%= displayed_content %></div><button data-message-expand-target="toggle" data-action="click->message-expand#toggle" class="btn btn-ghost btn-xs mt-2 hidden">Read more</button></div><%-
      else -%><div class="<%= is_loading ? 'animate-pulse opacity-70 italic' : '' %>"><%= displayed_content %></div><%-
      end -%></div>

    <div class="chat-footer opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      <button onclick="navigator.clipboard.writeText(this.dataset.content); return false;"
              data-content="<%= j message.content %>"
              class="btn btn-ghost btn-xs"
              title="Copy message">
        Copy
      </button>
      <% if sender_is_advisor %>
        <%= link_to interactions_conversation_message_path(message.conversation, message),
            class: "btn btn-ghost btn-xs btn-square",
            title: "View model interactions",
            aria: { label: "View model interactions" },
            data: { turbo_frame: "page-modal", page_modal_size: "fullscreen" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0m5.656 0L16 12.343m-2.172-2.171a4 4 0 010 5.656m0-5.656L12.343 8m1.485 1.485a4 4 0 00-5.656 5.656m0 0L6 12.343m2.172 2.828L10.343 16" />
          </svg>
        <% end %>
      <% end %>
      <% if is_advisor %>
        <% if is_api_error %>
          <%= button_to "Retry",
              retry_conversation_message_path(message.conversation, message),
              method: :post,
              class: "btn btn-ghost btn-xs",
              form: { data: { turbo_confirm: "Retry this advisor response?" } } %>
        <% end %>
      <% end %>
    </div>
  </div>

<% end %>
