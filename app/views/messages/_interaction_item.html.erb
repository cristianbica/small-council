<% request_payload = interaction.request_payload.is_a?(Hash) ? interaction.request_payload.deep_dup : {} %>
<% response_payload = interaction.response_payload.is_a?(Hash) ? interaction.response_payload : {} %>
<% request_tools = nil %>
<% if interaction.interaction_type == "chat" %>
  <% request_tools = request_payload.delete("tools") || request_payload.delete(:tools) %>
<% end %>

<div class="collapse collapse-arrow bg-base-200">
  <input type="checkbox" <%= 'checked' if expanded %> />
  <div class="collapse-title font-medium text-sm">
    <div class="flex items-center gap-3">
      <span class="badge badge-outline badge-sm">#<%= interaction.sequence + 1 %></span>
      <span><%= interaction.model_identifier.presence || interaction.interaction_type %></span>
      <span class="text-base-content/50">
        <%= interaction.input_tokens + interaction.output_tokens %> tokens
      </span>
      <% if interaction.duration_ms %>
        <span class="text-base-content/50"><%= interaction.duration_ms.round(0) %>ms</span>
      <% end %>
    </div>
  </div>
  <div class="collapse-content space-y-3">
    <div>
      <h4 class="text-xs font-semibold text-base-content/70 mb-1">Request</h4>
      <div class="bg-base-300 p-3 rounded-lg text-xs overflow-x-auto max-h-[22.5rem] overflow-y-auto">
        <pre class="whitespace-pre-wrap"><%= JSON.pretty_generate(request_payload) %></pre>
      </div>
    </div>

    <% if interaction.interaction_type == "chat" && request_tools.present? %>
      <div class="collapse collapse-arrow bg-base-300">
        <input type="checkbox" />
        <div class="collapse-title text-xs font-semibold text-base-content/70 py-2 min-h-0">
          Request Tools
        </div>
        <div class="collapse-content pt-0">
          <div class="p-3 rounded-lg text-xs overflow-x-auto max-h-[22.5rem] overflow-y-auto">
            <pre class="whitespace-pre-wrap"><%= JSON.pretty_generate(request_tools) %></pre>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <h4 class="text-xs font-semibold text-base-content/70 mb-1">Response</h4>
      <div class="bg-base-300 p-3 rounded-lg text-xs overflow-x-auto max-h-[22.5rem] overflow-y-auto">
        <pre class="whitespace-pre-wrap"><%= JSON.pretty_generate(response_payload) %></pre>
      </div>
    </div>
  </div>
</div>
