<%= turbo_frame_tag "message_#{message.id}", data: { action: "turbo:frame-load->conversation#messageRendered" } do %>
  <% is_current_user = message.sender == current_user %>
  <% is_pending = message.pending? %>
  <% is_error = message.error? %>
  <% is_advisor = message.advisor? %>
  <% sender_is_advisor = message.sender.is_a?(Advisor) %>
  <% sender_name = message.sender.respond_to?(:name) ? message.sender.name : message.sender.email %>
  <% alignment = is_current_user ? 'chat-end' : 'chat-start' %>
  <% bubble_class = is_current_user ? 'bg-primary text-primary-content' : 'bg-base-200 text-base-content' %>
  <% avatar_class = is_advisor ? 'bg-primary text-primary-content' : 'bg-neutral text-neutral-content' %>
  <% has_interactions = if defined?(@messages_with_interactions)
       @messages_with_interactions[message.id].present?
     else
       message.model_interactions.loaded? ? message.model_interactions.any? : message.model_interactions.exists?
     end %>
  <% show_interactions_button = sender_is_advisor && (is_pending || has_interactions) %>
  <% displayed_content = (sender_is_advisor && is_pending) ? "..." : message.content %>

  <div class="chat <%= alignment %> group" id="message_<%= message.id %>">
    <%# Avatar %>
    <div class="chat-image avatar">
      <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold <%= avatar_class %>">
        <%= sender_name.first.upcase %>
      </div>
    </div>

    <%# Header (name + timestamp + status indicators) %>
    <div class="chat-header">
      <%= sender_name %>
      <time class="text-xs opacity-60 ml-2" title="<%= message.created_at.strftime('%B %d, %Y at %I:%M %p') %>">
        <%= time_ago_in_words(message.created_at) %> ago
      </time>
      <% if is_pending %>
        <span class="loading loading-spinner loading-xs ml-2"></span>
      <% end %>
      <% if is_advisor && message.prompt_text.present? %>
        <button onclick="document.getElementById('debug-modal-<%= message.id %>').showModal()"
                class="btn btn-ghost btn-xs btn-circle ml-1"
                title="View debug info">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
      <% end %>
      <% if show_interactions_button %>
        <button onclick="const modal = document.getElementById('interactions-modal-<%= message.id %>'); const frame = document.getElementById('interactions-frame-<%= message.id %>'); if (frame && !frame.getAttribute('src')) { frame.setAttribute('src', '<%= interactions_conversation_message_path(message.conversation, message) %>'); } modal.showModal();"
                class="btn btn-ghost btn-xs btn-circle opacity-60 hover:opacity-100 ml-1"
                title="View model interactions">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </button>
      <% end %>
    </div>

    <%# Chat Bubble - using <%- to suppress whitespace %>
    <div class="chat-bubble <%= bubble_class %> text-sm max-w-[85%] sm:max-w-[75%] whitespace-pre-wrap"><%-
      if is_error -%><div class="flex items-center gap-2 text-error-content"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><%= displayed_content %></div><%-
      elsif sender_is_advisor && displayed_content.present? && displayed_content.length > 500 -%><div data-controller="message-expand" data-message-expand-max-length-value="500"><div data-message-expand-target="content" class="<%= is_pending ? 'animate-pulse' : '' %>"><%= displayed_content %></div><button data-message-expand-target="toggle" data-action="click->message-expand#toggle" class="btn btn-ghost btn-xs mt-2 hidden">Read more</button></div><%-
      else -%><div class="<%= is_pending ? 'animate-pulse opacity-70 italic' : '' %>"><%= displayed_content %></div><%-
      end -%></div>

    <%# Chat Footer with Actions (visible on hover) %>
    <div class="chat-footer opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      <%# Copy button %>
      <button onclick="navigator.clipboard.writeText(this.dataset.content); return false;"
              data-content="<%= j message.content %>"
              class="btn btn-ghost btn-xs"
              title="Copy message">
        Copy
      </button>
      <%# Advisor feedback actions %>
      <% if is_advisor %>
        <button class="btn btn-ghost btn-xs" title="Good response">👍</button>
        <button class="btn btn-ghost btn-xs" title="Bad response">👎</button>
        <button class="btn btn-ghost btn-xs" title="Regenerate">🔄</button>
      <% end %>
    </div>
  </div>

  <%# Debug Modal for Advisor Messages %>
  <% if is_advisor && message.prompt_text.present? %>
    <dialog id="debug-modal-<%= message.id %>" class="modal modal-bottom sm:modal-middle">
      <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Debug Information</h3>
        <div class="space-y-4">
          <div>
            <h4 class="text-sm font-semibold text-base-content/70 mb-1">System Prompt</h4>
            <div class="bg-base-200 p-3 rounded-lg text-sm whitespace-pre-wrap max-h-40 overflow-y-auto"><%= message.prompt_text %></div>
          </div>
          <% if message.debug_data.present? %>
            <div>
              <h4 class="text-sm font-semibold text-base-content/70 mb-1">Request Details</h4>
              <div class="bg-base-200 p-3 rounded-lg text-sm">
                <% if message.debug_data["request"] %>
                  <p><strong>Model:</strong> <%= message.debug_data["request"]["model"] %></p>
                  <p><strong>Provider:</strong> <%= message.debug_data["request"]["provider"] %></p>
                  <p><strong>Temperature:</strong> <%= message.debug_data["request"]["temperature"] %></p>
                  <p><strong>Max Tokens:</strong> <%= message.debug_data["request"]["max_tokens"] %></p>
                  <p><strong>Messages in Context:</strong> <%= message.debug_data["request"]["messages_count"] %></p>
                <% end %>
              </div>
            </div>
            <% if message.debug_data["response"] %>
              <div>
                <h4 class="text-sm font-semibold text-base-content/70 mb-1">Response Metadata</h4>
                <div class="bg-base-200 p-3 rounded-lg text-sm">
                  <p><strong>Input Tokens:</strong> <%= message.debug_data["response"]["input_tokens"] || "N/A" %></p>
                  <p><strong>Output Tokens:</strong> <%= message.debug_data["response"]["output_tokens"] || "N/A" %></p>
                  <p><strong>Model Used:</strong> <%= message.debug_data["response"]["model_used"] || "N/A" %></p>
                  <p><strong>Timestamp:</strong> <%= message.debug_data["response"]["timestamp"] || "N/A" %></p>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
        <div class="modal-action">
          <button onclick="document.getElementById('debug-modal-<%= message.id %>').close()" class="btn">Close</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>close</button>
      </form>
    </dialog>
  <% end %>

  <%# Model Interactions Modal %>
  <% if show_interactions_button %>
    <dialog id="interactions-modal-<%= message.id %>" class="modal modal-bottom sm:modal-middle">
      <div class="modal-box !max-w-[95vw] w-[95vw] h-[95vh]">
        <turbo-frame id="interactions-frame-<%= message.id %>">
          <div class="h-full flex items-center justify-center text-sm text-base-content/60">
            Loading interactions...
          </div>
        </turbo-frame>
        <div class="modal-action">
          <button onclick="document.getElementById('interactions-modal-<%= message.id %>').close()"
                  class="btn">Close</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>close</button>
      </form>
    </dialog>
  <% end %>
<% end %>
