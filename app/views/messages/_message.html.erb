<%= turbo_frame_tag "message_#{message.id}", data: { action: "turbo:frame-load->conversation#messageRendered" } do %>
  <% is_current_user = message.sender == current_user %>
  <% is_pending = message.pending? %>
  <% is_error = message.error? %>
  <% is_advisor = message.advisor? %>
  <% sender_name = message.sender.respond_to?(:name) ? message.sender.name : message.sender.email %>

  <div class="chat <%= is_current_user ? 'chat-end' : 'chat-start' %> group">
    <div class="chat-image avatar">
      <div class="w-10 rounded-full bg-neutral text-neutral-content flex items-center justify-center">
        <span class="text-xs"><%= sender_name.first.upcase %></span>
      </div>
    </div>

    <div class="chat-header">
      <span class="text-sm font-medium"><%= sender_name %></span>
      <time class="text-xs opacity-50" title="<%= message.created_at.strftime('%B %d, %Y at %I:%M %p') %>">
        <%= time_ago_in_words(message.created_at) %> ago
      </time>
      <% if is_pending %>
        <span class="loading loading-spinner loading-xs"></span>
      <% end %>
      <% if is_advisor && message.prompt_text.present? %>
        <button onclick="document.getElementById('debug-modal-<%= message.id %>').showModal()"
                class="btn btn-ghost btn-xs btn-circle"
                title="View debug info">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
      <% end %>
      <% if is_advisor && message.model_interactions.loaded? ? message.model_interactions.any? : message.model_interactions.exists? %>
        <button onclick="document.getElementById('interactions-modal-<%= message.id %>').showModal()"
                class="btn btn-ghost btn-xs btn-circle opacity-60 hover:opacity-100"
                title="View model interactions (<%= message.model_interactions.size %>)">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </button>
      <% end %>
    </div>

    <div class="chat-bubble <%=
      if is_error
        'chat-bubble-error'
      elsif is_pending
        'chat-bubble-neutral italic opacity-70'
      else
        'chat-bubble-neutral'
      end %> max-w-[70%] sm:max-w-[75%]">
      <% if is_advisor && message.content.present? && message.content.length > 500 %>
        <div data-controller="message-expand" data-message-expand-max-length-value="500">
          <div data-message-expand-target="content" class="whitespace-pre-wrap <%= is_pending ? 'animate-pulse' : '' %>"><%= message.content %></div>
          <button data-message-expand-target="toggle" data-action="click->message-expand#toggle" class="btn btn-ghost btn-xs mt-2 hidden">
            Read more
          </button>
        </div>
      <% else %>
        <div class="whitespace-pre-wrap <%= is_pending ? 'animate-pulse' : '' %>"><%= message.content %></div>
      <% end %>
    </div>

    <div class="chat-footer opacity-50">
      <!-- Copy button - appears on hover -->
      <button onclick="navigator.clipboard.writeText(this.dataset.content); return false;"
              data-content="<%= j message.content %>"
              class="opacity-0 group-hover:opacity-100 transition-opacity p-2 rounded-lg hover:bg-base-200"
              title="Copy message">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Debug Modal for Advisor Messages -->
  <% if is_advisor && message.prompt_text.present? %>
    <dialog id="debug-modal-<%= message.id %>" class="modal modal-bottom sm:modal-middle">
      <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Debug Information</h3>
        <div class="space-y-4">
          <div>
            <h4 class="text-sm font-semibold text-base-content/70 mb-1">System Prompt</h4>
            <div class="bg-base-200 p-3 rounded-lg text-sm whitespace-pre-wrap max-h-40 overflow-y-auto"><%= message.prompt_text %></div>
          </div>
          <% if message.debug_data.present? %>
            <div>
              <h4 class="text-sm font-semibold text-base-content/70 mb-1">Request Details</h4>
              <div class="bg-base-200 p-3 rounded-lg text-sm">
                <% if message.debug_data["request"] %>
                  <p><strong>Model:</strong> <%= message.debug_data["request"]["model"] %></p>
                  <p><strong>Provider:</strong> <%= message.debug_data["request"]["provider"] %></p>
                  <p><strong>Temperature:</strong> <%= message.debug_data["request"]["temperature"] %></p>
                  <p><strong>Max Tokens:</strong> <%= message.debug_data["request"]["max_tokens"] %></p>
                  <p><strong>Messages in Context:</strong> <%= message.debug_data["request"]["messages_count"] %></p>
                <% end %>
              </div>
            </div>
            <% if message.debug_data["response"] %>
              <div>
                <h4 class="text-sm font-semibold text-base-content/70 mb-1">Response Metadata</h4>
                <div class="bg-base-200 p-3 rounded-lg text-sm">
                  <p><strong>Input Tokens:</strong> <%= message.debug_data["response"]["input_tokens"] || "N/A" %></p>
                  <p><strong>Output Tokens:</strong> <%= message.debug_data["response"]["output_tokens"] || "N/A" %></p>
                  <p><strong>Model Used:</strong> <%= message.debug_data["response"]["model_used"] || "N/A" %></p>
                  <p><strong>Timestamp:</strong> <%= message.debug_data["response"]["timestamp"] || "N/A" %></p>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
        <div class="modal-action">
          <button onclick="document.getElementById('debug-modal-<%= message.id %>').close()" class="btn">Close</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>close</button>
      </form>
    </dialog>
  <% end %>

  <% if is_advisor && message.model_interactions.loaded? ? message.model_interactions.any? : message.model_interactions.exists? %>
    <dialog id="interactions-modal-<%= message.id %>" class="modal modal-bottom sm:modal-middle">
      <div class="modal-box max-w-4xl">
        <h3 class="font-bold text-lg mb-4">
          Model Interactions
          <span class="badge badge-neutral badge-sm ml-2"><%= message.model_interactions.size %></span>
        </h3>

        <div class="space-y-4">
          <% message.model_interactions.sort_by(&:sequence).each_with_index do |interaction, idx| %>
            <div class="collapse collapse-arrow bg-base-200">
              <input type="checkbox" <%= 'checked' if idx == 0 %> />
              <div class="collapse-title font-medium text-sm">
                <div class="flex items-center gap-3">
                  <span class="badge badge-outline badge-sm">#<%= interaction.sequence + 1 %></span>
                  <span><%= interaction.model_identifier %></span>
                  <span class="text-base-content/50">
                    <%= interaction.input_tokens + interaction.output_tokens %> tokens
                  </span>
                  <% if interaction.duration_ms %>
                    <span class="text-base-content/50"><%= interaction.duration_ms.round(0) %>ms</span>
                  <% end %>
                </div>
              </div>
              <div class="collapse-content space-y-3">
                <div>
                  <h4 class="text-xs font-semibold text-base-content/70 mb-1">Request</h4>
                  <div class="bg-base-300 p-3 rounded-lg text-xs overflow-x-auto max-h-60 overflow-y-auto">
                    <pre class="whitespace-pre-wrap"><%= JSON.pretty_generate(interaction.request_payload) %></pre>
                  </div>
                </div>
                <div>
                  <h4 class="text-xs font-semibold text-base-content/70 mb-1">Response</h4>
                  <div class="bg-base-300 p-3 rounded-lg text-xs overflow-x-auto max-h-60 overflow-y-auto">
                    <pre class="whitespace-pre-wrap"><%= JSON.pretty_generate(interaction.response_payload) %></pre>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="modal-action">
          <button onclick="document.getElementById('interactions-modal-<%= message.id %>').close()"
                  class="btn">Close</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>close</button>
      </form>
    </dialog>
  <% end %>
<% end %>
