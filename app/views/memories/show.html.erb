<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <%= link_to "Memories", space_memories_path(@space), class: "text-sm link" %>
        <span class="text-base-content/40">/</span>
        <h1 class="text-3xl font-bold"><%= @memory.title %></h1>
      </div>
      <div class="flex items-center gap-2 text-sm text-base-content/60">
        <span class="badge <%= memory_type_badge_class(@memory.memory_type) %> badge-sm">
          <%= @memory.memory_type_display %>
        </span>
        <span>Created <%= time_ago_in_words(@memory.created_at) %> ago</span>
        <% if @memory.source.present? %>
          <span>· From <%= @memory.source_display %></span>
        <% end %>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to "← Back", space_memories_path(@space), class: "btn btn-ghost btn-sm" %>
      <%= link_to "Edit", edit_space_memory_path(@space, @memory), class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  <!-- Memory Content -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="prose max-w-none markdown-body">
        <%= markdown_to_html(@memory.content) %>
      </div>
    </div>
  </div>

  <!-- Metadata -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h3 class="card-title text-sm mb-4">Details</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
        <div>
          <span class="text-base-content/60">Status</span>
          <p class="font-medium"><%= @memory.status_display %></p>
        </div>
        <div>
          <span class="text-base-content/60">Memory Type</span>
          <p class="font-medium"><%= @memory.memory_type_display %></p>
        </div>
        <div>
          <span class="text-base-content/60">Created By</span>
          <p class="font-medium"><%= @memory.creator_display %></p>
        </div>
        <div>
          <span class="text-base-content/60">Last Updated</span>
          <p class="font-medium"><%= time_ago_in_words(@memory.updated_at) %> ago</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Version History -->
  <% if @memory.versions.count > 1 %>
    <div class="card bg-base-100 shadow border-l-4 border-info">
      <div class="card-body">
        <h3 class="card-title text-sm mb-2">Version History</h3>
        <p class="text-sm text-base-content/60 mb-4">
          This memory has <%= @memory.versions.count %> versions. You can view previous versions or restore to an earlier state if needed.
        </p>
        <%= link_to "View Version History", versions_space_memory_path(@space, @memory), class: "btn btn-info btn-sm" %>
      </div>
    </div>
  <% end %>

  <!-- Actions -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h3 class="card-title text-sm mb-4">Actions</h3>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Edit Memory", edit_space_memory_path(@space, @memory), class: "btn btn-primary" %>
        <% if @memory.active? %>
          <%= button_to "Archive Memory", archive_space_memory_path(@space, @memory),
              method: :post,
              class: "btn btn-warning",
              data: { turbo_confirm: "Archive this memory? It will no longer be visible in the main list." } %>
        <% else %>
          <%= button_to "Activate Memory", activate_space_memory_path(@space, @memory),
              method: :post,
              class: "btn btn-success" %>
        <% end %>
        <%= button_to "Delete Memory", space_memory_path(@space, @memory),
            method: :delete,
            class: "btn btn-error btn-outline",
            data: { turbo_confirm: "Are you sure? This cannot be undone." } %>
      </div>
    </div>
  </div>
</div>
