<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold"><%= @space.name %> - Memories</h1>
      <p class="text-sm text-base-content/60">
        <%= pluralize(@memories.count, "memory") %> in this space
      </p>
    </div>
    <div class="flex gap-2">
      <%= link_to "← Back to Space", space_councils_path(@space), class: "btn btn-ghost btn-sm" %>
      <%= link_to "Export", export_space_memories_path(@space, format: :md),
          class: "btn btn-ghost btn-sm",
          title: "Export memories as Markdown" %>
      <%= link_to "+ New Memory", new_space_memory_path(@space), class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  <!-- Filters & Search -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="flex flex-col sm:flex-row gap-4">
        <!-- Type Filter -->
        <div class="flex gap-2 flex-wrap">
          <%= link_to "All", space_memories_path(@space),
              class: "btn btn-sm #{@selected_type.blank? ? 'btn-primary' : 'btn-ghost'}" %>
          <% @memory_types.each do |type| %>
            <%= link_to type.humanize, space_memories_path(@space, type: type),
                class: "btn btn-sm #{@selected_type == type ? 'btn-primary' : 'btn-ghost'}" %>
          <% end %>
        </div>

        <!-- Search -->
        <%= form_with url: search_space_memories_path(@space), method: :get, class: "flex gap-2 flex-1" do |f| %>
          <div class="form-control flex-1">
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-base-content/50">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </span>
              <%= f.text_field :q,
                  value: @search_query,
                  placeholder: "Search memories...",
                  class: "input input-bordered w-full pl-10 input-sm" %>
            </div>
          </div>
          <%= f.submit "Search", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Memories List -->
  <div class="space-y-4">
    <% if @memories.any? %>
      <% @memories.each do |memory| %>
        <div class="card bg-base-100 shadow hover:shadow-lg transition-shadow">
          <div class="card-body">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="card-title text-lg">
                    <%= link_to memory.title, space_memory_path(@space, memory), class: "link link-hover" %>
                  </h3>
                  <span class="badge badge-sm <%= memory_type_badge_class(memory.memory_type) %>">
                    <%= memory.memory_type_display %>
                  </span>
                  <% if memory.archived? %>
                    <span class="badge badge-sm badge-ghost">Archived</span>
                  <% end %>
                </div>

                <p class="text-sm text-base-content/60 mb-2">
                  Created <%= time_ago_in_words(memory.created_at) %> ago
                  <% if memory.source.present? %>
                    · From <%= memory.source_display %>
                  <% end %>
                </p>

                <p class="text-base-content/80 line-clamp-3">
                  <%= memory.content_preview %>
                </p>
              </div>

              <div class="flex flex-col gap-1 ml-4">
                <%= link_to "View", space_memory_path(@space, memory), class: "btn btn-xs btn-ghost" %>
                <%= link_to "Edit", edit_space_memory_path(@space, memory), class: "btn btn-xs btn-ghost" %>
                <% if memory.active? %>
                  <%= button_to "Archive", archive_space_memory_path(@space, memory),
                      method: :post,
                      class: "btn btn-xs btn-ghost text-warning",
                      data: { turbo_confirm: "Archive this memory?" } %>
                <% else %>
                  <%= button_to "Activate", activate_space_memory_path(@space, memory),
                      method: :post,
                      class: "btn btn-xs btn-ghost text-success" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="card bg-base-100 shadow">
        <div class="card-body text-center py-12">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-base-content/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <h3 class="text-xl font-semibold mb-2">No memories yet</h3>
          <p class="text-base-content/60 max-w-md mx-auto mb-4">
            Memories are the knowledge base for your space. Create your first memory to start building your space's knowledge.
          </p>
          <%= link_to "Create Your First Memory", new_space_memory_path(@space), class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
