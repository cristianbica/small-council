<div class="max-w-2xl mx-auto space-y-6">
  <!-- Header -->
  <div>
    <div class="flex items-center gap-2 mb-1">
      <%= link_to "Memories", space_memories_path(@space), class: "text-sm link" %>
      <span class="text-base-content/40">/</span>
      <h1 class="text-3xl font-bold">New Memory</h1>
    </div>
    <p class="text-sm text-base-content/60">
      Create a new memory in <%= @space.name %>
    </p>
  </div>

  <!-- Form -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <%= render "form", space: @space, memory: @memory %>
    </div>
  </div>
</div>
