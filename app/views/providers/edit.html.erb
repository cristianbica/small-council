<div class="space-y-6 max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold">Edit Provider</h1>

  <%= form_with model: @provider, class: "card bg-base-100 shadow" do |form| %>
    <div class="card-body space-y-4">
      <% if @provider.errors.any? %>
        <div class="alert alert-error">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h3 class="font-bold"><%= pluralize(@provider.errors.count, "error") %> prohibited this provider from being saved:</h3>
            <ul class="mt-1 list-disc list-inside text-sm">
              <% @provider.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <div class="form-control">
        <label class="label">
          <span class="label-text">
            Name
            <span class="text-error" aria-label="required">*</span>
          </span>
        </label>
        <%= form.text_field :name,
            class: "input input-bordered #{'input-error' if form.object.errors[:name].any?}",
            required: true %>
        <% if form.object.errors[:name].any? %>
          <label class="label">
            <span class="label-text-alt text-error flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= form.object.errors[:name].first %>
            </span>
          </label>
        <% end %>
      </div>

      <div class="form-control">
        <label class="label">
          <span class="label-text">Provider Type</span>
        </label>
        <%= form.select :provider_type,
            Provider.provider_types.keys.map { |t| [t.humanize, t] },
            {},
            class: "select select-bordered",
            disabled: true %>
        <label class="label">
          <span class="label-text-alt text-base-content/60">Provider type cannot be changed</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label">
          <span class="label-text">API Key</span>
          <span class="label-text-alt text-base-content/60">Leave blank to keep existing</span>
        </label>
        <%= form.password_field :api_key,
            class: "input input-bordered #{'input-error' if form.object.errors[:api_key].any?}",
            placeholder: "Leave blank to keep current" %>
        <label class="label">
          <span class="label-text-alt text-base-content/60">Your API key is encrypted at rest</span>
        </label>
        <% if form.object.errors[:api_key].any? %>
          <label class="label">
            <span class="label-text-alt text-error flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= form.object.errors[:api_key].first %>
            </span>
          </label>
        <% end %>
      </div>

      <div class="form-control">
        <label class="label">
          <span class="label-text">Organization ID</span>
          <span class="label-text-alt text-base-content/60">Optional</span>
        </label>
        <%= form.text_field :organization_id,
            class: "input input-bordered #{'input-error' if form.object.errors[:organization_id].any?}" %>
        <% if form.object.errors[:organization_id].any? %>
          <label class="label">
            <span class="label-text-alt text-error flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= form.object.errors[:organization_id].first %>
            </span>
          </label>
        <% end %>
      </div>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-3">
          <%= form.check_box :enabled, class: "checkbox checkbox-primary" %>
          <span class="label-text">Enabled</span>
        </label>
      </div>

      <div class="card-actions justify-end">
        <%= link_to "Cancel", providers_path, class: "btn btn-ghost" %>
        <%= form.submit "Update Provider", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
