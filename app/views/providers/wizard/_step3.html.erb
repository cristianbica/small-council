<% provider_type = @wizard_data[:provider_type] %>
<% provider_name = case provider_type
  when "openai" then "OpenAI"
  when "anthropic" then "Anthropic"
  when "github" then "GitHub Models"
  else provider_type&.humanize || "Provider"
  end
%>

<div class="flex items-center gap-2 mb-4">
  <%= form_with url: wizard_back_providers_path, method: :post do |f| %>
    <%= f.submit "← Back", class: "btn btn-ghost btn-sm" %>
  <% end %>
</div>

<h2 class="card-title mb-2">Test Connection</h2>
<p class="text-base-content/70 mb-6">We'll validate your <%= provider_name %> credentials and fetch available models.</p>

<div data-controller="provider-wizard"
     data-provider-wizard-provider-type-value="<%= provider_type %>"
     data-provider-wizard-api-key-value="<%= @wizard_data[:api_key] %>"
     data-provider-wizard-organization-id-value="<%= @wizard_data[:organization_id] %>">

  <!-- Loading State -->
  <div data-provider-wizard-target="loading" class="text-center py-8">
    <span class="loading loading-spinner loading-lg text-primary"></span>
    <p class="mt-4 text-base-content/70">Testing connection to <%= provider_name %>...</p>
  </div>

  <!-- Success State -->
  <div data-provider-wizard-target="success" class="hidden">
    <div class="alert alert-success mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="font-bold">Connection successful!</h3>
        <p class="text-sm">Your API key is valid and working.</p>
      </div>
    </div>

    <div class="bg-base-200 rounded-lg p-4 mb-6">
      <h4 class="font-semibold mb-2">Available Models:</h4>
      <ul data-provider-wizard-target="modelsList" class="space-y-1 text-sm max-h-40 overflow-y-auto">
        <!-- Models will be populated here -->
      </ul>
    </div>

    <%= form_with url: wizard_step_providers_path, method: :post, class: "card-actions justify-end" do |f| %>
      <%= f.submit "Continue →", class: "btn btn-primary" %>
    <% end %>
  </div>

  <!-- Error State -->
  <div data-provider-wizard-target="error" class="hidden">
    <div class="alert alert-error mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="font-bold">Connection failed</h3>
        <p data-provider-wizard-target="errorMessage" class="text-sm">Invalid API key</p>
      </div>
    </div>

    <div class="card-actions justify-between">
      <%= form_with url: wizard_back_providers_path, method: :post do |f| %>
        <%= f.submit "← Back", class: "btn btn-ghost" %>
      <% end %>
      <%= form_with url: wizard_step_providers_path, method: :post do |f| %>
        <%= f.submit "Try Again", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
</div>
