<h2 class="card-title mb-6">Choose your AI Provider</h2>

<%= form_with url: wizard_step_providers_path, method: :post, class: "space-y-4" do |f| %>
  <div class="space-y-3">
    <!-- OpenAI -->
    <label class="cursor-pointer block">
      <%= f.radio_button :provider_type, "openai", class: "peer sr-only", required: true %>
      <div class="flex items-center gap-4 p-4 bg-base-200 peer-checked:bg-primary peer-checked:text-primary-content hover:bg-base-300 transition-colors rounded-lg border-2 border-transparent peer-checked:border-primary">
        <div class="w-10 h-10 rounded-lg bg-base-100 peer-checked:bg-primary-content/20 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold">OpenAI</h3>
          <p class="text-sm opacity-70">GPT-4, GPT-3.5, and other OpenAI models</p>
        </div>
        <div class="w-5 h-5 rounded-full border-2 border-current peer-checked:bg-primary-content peer-checked:border-primary-content flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-0 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>
    </label>

    <!-- OpenRouter -->
    <label class="cursor-pointer block">
      <%= f.radio_button :provider_type, "openrouter", class: "peer sr-only" %>
      <div class="flex items-center gap-4 p-4 bg-base-200 peer-checked:bg-primary peer-checked:text-primary-content hover:bg-base-300 transition-colors rounded-lg border-2 border-transparent peer-checked:border-primary">
        <div class="w-10 h-10 rounded-lg bg-base-100 peer-checked:bg-primary-content/20 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold">OpenRouter</h3>
          <p class="text-sm opacity-70">Access to multiple AI models through a unified API</p>
        </div>
        <div class="w-5 h-5 rounded-full border-2 border-current peer-checked:bg-primary-content peer-checked:border-primary-content flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-0 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>
    </label>
  </div>

  <div class="card-actions justify-end mt-6">
    <%= f.submit "Continue →", class: "btn btn-primary" %>
  </div>
<% end %>
