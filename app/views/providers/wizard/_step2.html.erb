<% provider_type = @wizard_data[:provider_type] %>
<% provider_name = provider_type&.humanize || "Provider" %>

<div class="mb-6">
  <%= button_to "← Back", wizard_back_providers_path, method: :post, class: "btn btn-ghost btn-sm" %>
</div>

<h2 class="card-title mb-2">Authenticate with <%= provider_name %></h2>
<p class="text-base-content/70 mb-6">Enter your API credentials to connect.</p>

<%= form_with url: wizard_step_providers_path, method: :post, class: "space-y-4", data: { turbo: false } do |f| %>
  <div class="form-control">
    <label class="label">
      <span class="label-text font-medium">
        <% if provider_type == "github" %>
          GitHub Personal Access Token
        <% else %>
          API Key
        <% end %>
        <span class="text-error">*</span>
      </span>
    </label>
    <%= f.password_field :api_key,
        class: "input input-bordered w-full",
        placeholder: provider_type == "openai" ? "sk-..." : "Enter your API key",
        required: true,
        autocomplete: "off" %>
    <label class="label">
      <span class="label-text-alt">
        <% case provider_type %>
        <% when "openai" %>
          <%= link_to "Get your API key →", "https://platform.openai.com/api-keys", target: "_blank", class: "link link-primary" %>
        <% when "anthropic" %>
          <%= link_to "Get your API key →", "https://console.anthropic.com/settings/keys", target: "_blank", class: "link link-primary" %>
        <% when "github" %>
          <%= link_to "Create a GitHub token →", "https://github.com/settings/tokens", target: "_blank", class: "link link-primary" %>
        <% end %>
      </span>
    </label>
  </div>

  <% if provider_type == "openai" %>
    <div class="form-control">
      <label class="label">
        <span class="label-text font-medium">Organization ID</span>
        <span class="label-text-alt">Optional</span>
      </label>
      <%= f.text_field :organization_id,
          class: "input input-bordered w-full",
          placeholder: "org-..." %>
      <label class="label">
        <span class="label-text-alt">Only needed for OpenAI enterprise accounts</span>
      </label>
    </div>
  <% end %>

  <div class="card-actions justify-between mt-6 pt-4 border-t border-base-200">
    <%= button_to "← Back", wizard_back_providers_path, method: :post, class: "btn btn-ghost" %>
    <%= f.submit "Continue →", class: "btn btn-primary" %>
  </div>
<% end %>
