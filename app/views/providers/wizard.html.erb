<div class="max-w-2xl mx-auto">
  <!-- Wizard Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Add AI Provider</h1>
    <p class="text-base-content/70">Step <%= @step %> of 4</p>

    <!-- Progress Bar -->
    <div class="w-full bg-base-200 rounded-full h-2 mt-4">
      <div class="bg-primary h-2 rounded-full transition-all duration-300" style="width: <%= @step * 25 %>"></div>
    </div>
  </div>

  <!-- Step Content -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <%= case @step
        when 1 then render "providers/wizard/step1"
        when 2 then render "providers/wizard/step2"
        when 3 then render "providers/wizard/step3"
        when 4 then render "providers/wizard/step4"
      end %>
    </div>
  </div>

  <!-- Cancel Link -->
  <div class="mt-4 text-center">
    <%= button_to "Cancel", wizard_cancel_providers_path, method: :post, class: "btn btn-ghost btn-sm" %>
  </div>
</div>
