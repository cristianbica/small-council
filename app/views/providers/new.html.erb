<div class="space-y-6 max-w-3xl mx-auto">
  <div>
    <h1 class="text-3xl font-bold">Add Provider</h1>
    <p class="text-base-content/70 mt-1">Choose a provider, test the connection, then save.</p>
  </div>

  <div class="grid gap-3 sm:grid-cols-3">
    <%= link_to new_provider_path(provider_type: "openai"),
        class: "card border #{@selected_provider_type == 'openai' ? 'border-primary bg-primary/5' : 'border-base-300 bg-base-100'} hover:border-primary transition-colors",
        data: { turbo_frame: "provider_form_frame" } do %>
      <div class="card-body p-4">
        <h2 class="font-semibold">OpenAI</h2>
        <p class="text-sm text-base-content/70">GPT models with optional organization support.</p>
      </div>
    <% end %>

    <%= link_to new_provider_path(provider_type: "openrouter"),
        class: "card border #{@selected_provider_type == 'openrouter' ? 'border-primary bg-primary/5' : 'border-base-300 bg-base-100'} hover:border-primary transition-colors",
        data: { turbo_frame: "provider_form_frame" } do %>
      <div class="card-body p-4">
        <h2 class="font-semibold">OpenRouter</h2>
        <p class="text-sm text-base-content/70">One key for multiple model providers.</p>
      </div>
    <% end %>

    <%= link_to new_provider_path(provider_type: "anthropic"),
        class: "card border #{@selected_provider_type == 'anthropic' ? 'border-primary bg-primary/5' : 'border-base-300 bg-base-100'} hover:border-primary transition-colors",
        data: { turbo_frame: "provider_form_frame" } do %>
      <div class="card-body p-4">
        <h2 class="font-semibold">Anthropic</h2>
        <p class="text-sm text-base-content/70">Claude models directly from Anthropic.</p>
      </div>
    <% end %>
  </div>

  <%= render "providers/provider_form_frame",
      provider: @provider,
      selected_provider_type: @selected_provider_type %>
</div>
