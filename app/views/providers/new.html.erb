<div class="space-y-6 max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold">Add Provider</h1>

  <%= form_with model: @provider, class: "card bg-base-100 shadow" do |form| %>
    <div class="card-body space-y-4">
      <% if @provider.errors.any? %>
        <div class="alert alert-error">
          <ul class="list-disc list-inside">
            <% @provider.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-control">
        <%= form.label :name, class: "label" %>
        <%= form.text_field :name, class: "input input-bordered", placeholder: "e.g., OpenAI Production", required: true %>
      </div>

      <div class="form-control">
        <%= form.label :provider_type, "Provider Type", class: "label" %>
        <%= form.select :provider_type, 
            Provider.provider_types.keys.map { |t| [t.humanize, t] },
            {}, 
            class: "select select-bordered",
            required: true %>
      </div>

      <div class="form-control">
        <%= form.label :api_key, "API Key", class: "label" %>
        <%= form.password_field :api_key, class: "input input-bordered", placeholder: "sk-...", required: true %>
        <label class="label">
          <span class="label-text-alt text-base-content/60">Your API key is encrypted at rest</span>
        </label>
      </div>

      <div class="form-control">
        <%= form.label :organization_id, "Organization ID (optional)", class: "label" %>
        <%= form.text_field :organization_id, class: "input input-bordered", placeholder: "org-..." %>
        <label class="label">
          <span class="label-text-alt text-base-content/60">Only required for OpenAI enterprise accounts</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-2">
          <%= form.check_box :enabled, class: "checkbox" %>
          <span class="label-text">Enabled</span>
        </label>
      </div>

      <div class="card-actions justify-end">
        <%= link_to "Cancel", providers_path, class: "btn btn-ghost" %>
        <%= form.submit "Add Provider", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
