<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">AI Providers</h1>
      <p class="text-base-content/70 mt-1">Manage your AI service providers and models</p>
    </div>
    <%= link_to "Add Provider", wizard_providers_path, class: "btn btn-primary" %>
  </div>

  <% if @providers.any? %>
    <div class="space-y-4">
      <% @providers.each do |provider| %>
        <div class="card bg-base-100 shadow">
          <div class="card-body p-4">
            <div class="flex items-center justify-between">
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold truncate"><%= provider.name %></h3>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-sm text-base-content/60">Type: <%= provider.provider_type.humanize %></span>
                  <span class="text-base-content/30">·</span>
                  <span class="badge <%= provider.enabled? ? 'badge-success' : 'badge-error' %> badge-sm">
                    <%= provider.enabled? ? "Enabled" : "Disabled" %>
                  </span>
                  <span class="text-base-content/30">·</span>
                  <span class="text-sm text-base-content/60"><%= provider.llm_models.enabled.count %> enabled models</span>
                </div>
              </div>
              <div class="flex items-center gap-2 ml-4">
                <%= link_to models_provider_path(provider),
                    class: "btn btn-sm btn-ghost",
                    title: "Manage models" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                  </svg>
                  Models
                <% end %>
                <%= link_to "Edit", edit_provider_path(provider), class: "btn btn-sm btn-ghost" %>
                <%= button_to "Remove", provider_path(provider), method: :delete,
                    class: "btn btn-sm btn-ghost text-error",
                    data: { turbo_confirm: "Are you sure? This will remove all associated models." } %>
              </div>
            </div>

            <% if provider.llm_models.enabled.any? %>
              <div class="divider my-3"></div>
              <div>
                <h4 class="text-sm font-semibold mb-2">Active Models:</h4>
                <div class="flex flex-wrap gap-2">
                  <% provider.llm_models.enabled.each do |model| %>
                    <span class="badge badge-sm badge-outline"><%= model.name %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
        title: "No providers configured",
        description: "Add an AI provider to start using AI advisors in your councils.",
        action_path: wizard_providers_path,
        action_text: "Add your first provider" %>
  <% end %>
</div>
