<!-- Chat Interface -->
<div data-controller="scribe-chat"
     data-scribe-chat-space-id-value="<%= @space.id %>"
     class="flex flex-col h-full">

  <!-- Messages Area -->
  <div data-scribe-chat-target="messages"
       class="flex-1 overflow-y-auto p-6 space-y-4">
    <!-- Welcome Message -->
    <div class="flex gap-3">
      <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-primary-content text-sm font-bold shrink-0">
        S
      </div>
      <div class="flex-1">
        <div class="bg-base-200 rounded-lg p-4 max-w-2xl">
          <p class="text-base-content">Hello! I'm the Scribe, your assistant for managing knowledge in this space. I can help you:</p>
          <ul class="mt-2 ml-4 text-sm text-base-content/80 list-disc">
            <li>Create memories to save important information</li>
            <li>Search and query existing memories</li>
            <li>Find and read past conversations</li>
            <li>Suggest how to organize and structure knowledge</li>
          </ul>
          <p class="mt-2 text-sm text-base-content/60">How can I help you today?</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Suggestions -->
  <div data-scribe-chat-target="suggestions"
       class="px-6 py-2 border-t border-base-300 bg-base-100">
    <div class="flex flex-wrap gap-2">
      <button data-action="scribe-chat#sendQuick"
              data-message="What do we know about this space?"
              class="btn btn-xs btn-ghost">
        What do we know?
      </button>
      <button data-action="scribe-chat#sendQuick"
              data-message="Summarize the key decisions we've made"
              class="btn btn-xs btn-ghost">
        Key decisions
      </button>
      <button data-action="scribe-chat#sendQuick"
              data-message="Help me draft content for a new memory"
              class="btn btn-xs btn-ghost">
        Draft memory content
      </button>
      <button data-action="scribe-chat#sendQuick"
              data-message="Show recent conversations"
              class="btn btn-xs btn-ghost">
        Recent conversations
      </button>
    </div>
  </div>

  <!-- Input Area -->
  <div class="p-4 border-t border-base-300 bg-base-100">
    <div class="flex gap-2">
      <div class="flex-1 relative">
        <textarea data-scribe-chat-target="input"
                  data-action="keydown->scribe-chat#handleKeydown input->scribe-chat#autoExpand"
                  placeholder="Ask the Scribe something... (Shift+Enter for new line)"
                  class="textarea textarea-bordered w-full resize-none"
                  rows="2"></textarea>
      </div>
      <button data-action="scribe-chat#send"
              data-scribe-chat-target="sendButton"
              class="btn btn-primary h-auto min-h-[4rem]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </div>
    <p class="text-xs text-base-content/40 mt-2">
      Press Enter to send. I can create memories, search existing ones, and read conversations.
    </p>
  </div>

  <!-- Loading Indicator (hidden by default) -->
  <div data-scribe-chat-target="loading"
       class="hidden fixed inset-0 bg-black/20 flex items-center justify-center z-50">
    <div class="bg-base-100 rounded-lg p-4 shadow-lg flex items-center gap-3">
      <span class="loading loading-spinner loading-md text-primary"></span>
      <span>Scribe is thinking...</span>
    </div>
  </div>
</div>
