<div class="h-[calc(100vh-4rem)] flex">
  <!-- Sidebar: Memory Browser -->
  <div class="w-80 bg-base-200 border-r border-base-300 flex flex-col">
    <%= render "memory_browser" %>
  </div>

  <!-- Main: Chat Interface -->
  <div class="flex-1 flex flex-col">
    <!-- Header -->
    <div class="border-b border-base-300 bg-base-100 px-6 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold">Chat with Scribe</h1>
          <p class="text-sm text-base-content/60">
            <%= @space.name %> · Managing <%= pluralize(@memories.count, "memory") %>
          </p>
        </div>
        <div class="flex gap-2">
          <%= link_to "← Back to Space", space_councils_path(@space), class: "btn btn-ghost btn-sm" %>
          <%= link_to "Memories", space_memories_path(@space), class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>

    <!-- Chat Area -->
    <div class="flex-1 overflow-hidden">
      <%= render "chat" %>
    </div>
  </div>
</div>
